  "description": "Pre-rendered Sakha safety audio bundle. Three categories × 10 languages = 30 clips. Each clip is locked to the per-language voice_id in tts_router.DEFAULT_VOICE_IDS so the same Sakha that speaks during a normal turn also speaks the safety messages — no jarring voice switch when the user enters crisis or hits quota.",
  "languages": ["en", "hi", "mr", "bn", "ta", "te", "pa", "gu", "kn", "ml"],
  "categories": {
    "crisis_routing": {
      "purpose": "Routed when CrisisPartialScanner detects ideation. Plays while the CrisisOverlay mounts; the user is then routed to local helplines.",
      "served_at": "/static/voice/safety/crisis_routing.{lang}.opus",
      "english_master_text": "I am right here with you. What you are feeling is real, and there is help — right now, on this phone. Please call the number on your screen. I will wait.",
      "max_duration_sec": 25,
      "non_negotiable": true,
      "filter_check": "must_anchor_with_canonical_warmth_no_clinical_jargon"
    },
    "quota_upgrade": {
      "purpose": "Played gently when a user on a paid tier exhausts daily minutes mid-turn. Free-tier first attempt also plays this.",
      "served_at": "/static/voice/safety/quota_upgrade.{lang}.opus",
      "english_master_text": "We have reached the rest of today's voice together. Walk further when it feels right. I am still here in silence.",
      "max_duration_sec": 18,
      "non_negotiable": false,
      "filter_check": "no_pressure_no_countdown"
    },
    "silence_hum": {
      "purpose": "Soft 'मौन में सखा' (Sakha in silence) clip used during offline state and graceful network-loss degradation per spec.",
      "served_at": "/static/voice/safety/silence_hum.{lang}.opus",
      "english_master_text": "[Soft, breath-paced sustained tone with a single barely-audible 'हम्म' at end. No words.]",
      "max_duration_sec": 8,
      "non_negotiable": false,
      "filter_check": "no_words_required"
    }
  },
