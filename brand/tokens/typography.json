{
  "meta": {
    "description": "Kiaanverse Unified Typography — MindVibe + KIAAN + Sakha",
    "voice": "Gentle, clear, emotionally intelligent, sacred."
  },
  "fonts": {
    "divine": "'Cormorant Garamond', 'Georgia', serif",
    "scripture": "'Crimson Text', 'Georgia', 'Times New Roman', serif",
    "display": "'Playfair Display', 'Georgia', serif",
    "ui": "'Outfit', system-ui, -apple-system, sans-serif",
    "devanagari": "'Noto Sans Devanagari', 'Mangal', 'Arial Unicode MS', sans-serif"
  },
  "scale": {
    "5xl": { "size": "54px", "mobileSize": "40px", "lineHeight": "1.1", "weight": 300, "tracking": "-0.02em", "font": "divine" },
    "4xl": { "size": "42px", "mobileSize": "36px", "lineHeight": "1.15", "weight": 300, "tracking": "-0.01em", "font": "divine" },
    "3xl": { "size": "32px", "mobileSize": "28px", "lineHeight": "1.2", "weight": 300, "tracking": "-0.01em", "font": "divine" },
    "2xl": { "size": "26px", "mobileSize": "24px", "lineHeight": "1.3", "weight": 400, "tracking": "0", "font": "divine" },
    "xl": { "size": "21px", "mobileSize": "20px", "lineHeight": "1.4", "weight": 400, "tracking": "0", "font": "divine" },
    "lg": { "size": "18px", "mobileSize": "17px", "lineHeight": "1.65", "weight": 400, "tracking": "0", "font": "scripture" },
    "base": { "size": "16px", "mobileSize": "16px", "lineHeight": "1.6", "weight": 400, "tracking": "0", "font": "ui" },
    "sm": { "size": "14px", "mobileSize": "14px", "lineHeight": "1.5", "weight": 400, "tracking": "0.01em", "font": "ui" },
    "label": { "size": "13px", "mobileSize": "13px", "lineHeight": "1.4", "weight": 500, "tracking": "0.02em", "font": "ui" },
    "caption": { "size": "12px", "mobileSize": "12px", "lineHeight": "1.4", "weight": 400, "tracking": "0.02em", "font": "ui" },
    "micro": { "size": "11px", "mobileSize": "10px", "lineHeight": "1.3", "weight": 500, "tracking": "0.12em", "font": "ui" },
    "sacred": { "size": "20px", "mobileSize": "18px", "lineHeight": "1.85", "weight": 400, "tracking": "0.04em", "font": "scripture" },
    "sacred-sm": { "size": "16px", "mobileSize": "15px", "lineHeight": "1.75", "weight": 400, "tracking": "0.03em", "font": "scripture" }
  },
  "wordmarks": {
    "mindvibe": { "tracking": "0.06em", "case": "Title", "style": "Rounded humanist sans" },
    "kiaan": { "tracking": "0.14em", "case": "Upper", "style": "Embossed, crisp" },
    "tagline": "Your Guide to Inner Peace"
  }
}
