{
  "name": "kiaanverse-mobile-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "exclude": ["expo-in-app-purchases", "expo-font"]
    },
    "install": {
      "exclude": ["expo-in-app-purchases"]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/ components/ hooks/ services/ utils/",
    "test": "jest --passWithNoTests",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"utils/**/*.{ts,tsx}\"",
    "clean": "rm -rf .expo dist node_modules/.cache",
    "eas-build-pre-install": "bash ./eas-build-pre-install.sh || true",
    "eas-build-post-install": "find $(pwd)/../../node_modules -type d -name expo-in-app-purchases -exec rm -rf {} + 2>/dev/null; echo done"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react-native": "~5.33.0",
    "@kiaanverse/api": "workspace:*",
    "@kiaanverse/i18n": "workspace:*",
    "@kiaanverse/store": "workspace:*",
    "@kiaanverse/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@tanstack/query-async-storage-persister": "^5.60.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-query-persist-client": "^5.60.0",
    "axios": "^1.7.9",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-camera": "~15.0.0",
    "expo-constants": "~16.0.0",
    "expo-linear-gradient": "~13.0.0",
    "expo-font": "~12.0.0",
    "expo-haptics": "~13.0.0",
    "expo-linking": "~6.3.0",
    "expo-local-authentication": "~14.0.0",
    "expo-notifications": "~0.28.0",
    "expo-task-manager": "~11.8.0",
    "expo-background-fetch": "~12.0.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-speech": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "lucide-react-native": "^0.468.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "@shopify/react-native-skia": "^1.3.0",
    "lottie-react-native": "^7.0.0",
    "react-native-track-player": "^4.1.0",
    "expo-crypto": "~13.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.0",
    "@types/react-test-renderer": "^18.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.1.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  }
}
