{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"],
      "@kiaan/ui": ["../../packages/ui/src"],
      "@kiaan/ui/*": ["../../packages/ui/src/*"],
      "@kiaan/api": ["../../packages/api/src"],
      "@kiaan/api/*": ["../../packages/api/src/*"],
      "@kiaan/store": ["../../packages/store/src"],
      "@kiaan/store/*": ["../../packages/store/src/*"],
      "@kiaan/i18n": ["../../packages/i18n/src"],
      "@kiaan/i18n/*": ["../../packages/i18n/src/*"],
      "@kiaanverse/ui": ["../../packages/ui/src"],
      "@kiaanverse/api": ["../../packages/api/src"],
      "@kiaanverse/store": ["../../packages/store/src"],
      "@kiaanverse/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "*.ts", "*.js"],
  "exclude": ["node_modules"]
}
