{
  "name": "@kiaanverse/sakha-mobile",
  "version": "1.0.0-rc.1",
  "private": true,
  "main": "expo-router/entry",
  "description": "Sakha — Krishna's voice as a companion. Native Android module shipped as a signed .aab via Expo EAS.",
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-in-app-purchases"
      ]
    },
    "install": {
      "exclude": [
        "expo-in-app-purchases"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "typecheck": "tsc --noEmit",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint app/ lib/ plugins/",
    "test": "jest --passWithNoTests",
    "test:e2e:android": "detox test --configuration android.emu.release",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:android:production": "eas build --profile production --platform android",
    "submit:android": "eas submit --platform android --latest",
    "validate:plugins": "node scripts/validate-plugins.mjs",
    "validate:wss-types": "node scripts/validate-wss-types.mjs",
    "clean": "rm -rf .expo dist node_modules/.cache android ios"
  },
  "dependencies": {
    "@kiaanverse/sakha-voice-native": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@sentry/react-native": "~5.33.0",
    "@shopify/react-native-skia": "^1.3.0",
    "axios": "^1.7.9",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-build-properties": "~0.12.0",
    "expo-constants": "~16.0.0",
    "expo-crypto": "~13.0.0",
    "expo-file-system": "~17.0.0",
    "expo-haptics": "~13.0.0",
    "expo-linear-gradient": "~13.0.0",
    "expo-linking": "~6.3.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-sqlite": "~14.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-task-manager": "~11.8.0",
    "lottie-react-native": "^7.0.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.0",
    "cross-env": "^7.0.3",
    "detox": "^20.20.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "typescript": "~5.3.3"
  }
}
