{
  "name": "kiaanverse-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter kiaanverse-mobile-app start",
    "android": "pnpm --filter kiaanverse-mobile-app android",
    "ios": "pnpm --filter kiaanverse-mobile-app ios",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter kiaanverse-mobile-app test",
    "format:check": "pnpm --filter kiaanverse-mobile-app format:check",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "~5.3.3"
  }
}
